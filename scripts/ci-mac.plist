<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- launchd agent for the andreai Mac GPU CI runner. Deploy on an always-on Apple-Silicon Mac:
       1. Clone a DEDICATED checkout:  git clone <origin> ~/ci/andreai
       2. Substitute the home path:    sed "s#__HOME__#$HOME#g" ~/ci/andreai/scripts/ci-mac.plist \
                                         > ~/Library/LaunchAgents/nu.andreai.ci.plist
       3. Load it:                     launchctl load ~/Library/LaunchAgents/nu.andreai.ci.plist
     It polls origin/main every 30 min and runs the §5 + bufsan gate only when it advances.
     Verdict + log: ~/.andreai-ci-report.txt ; last-tested commit: ~/.andreai-ci-last . -->
<plist version="1.0">
<dict>
  <key>Label</key><string>nu.andreai.ci</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__HOME__/ci/andreai/scripts/ci-mac-poll.sh</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>__HOME__/.cargo/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>ANDREAI_CI_REPO</key><string>__HOME__/ci/andreai</string>
  </dict>
  <key>StartInterval</key><integer>1800</integer>
  <key>RunAtLoad</key><true/>
  <key>StandardOutPath</key><string>__HOME__/.andreai-ci-launchd.log</string>
  <key>StandardErrorPath</key><string>__HOME__/.andreai-ci-launchd.log</string>
</dict>
</plist>
